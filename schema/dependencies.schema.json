{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/japanese-language-taxonomy/schema/dependencies.schema.json",
  "title": "Japanese Language Taxonomy dependencies",
  "type": "object",
  "required": ["version", "profile", "edgeCount", "dependencies"],
  "properties": {
    "version": { "type": "string" },
    "profile": { "enum": ["ja-L1-child", "ja-L2-adult"] },
    "edgeCount": { "type": "integer", "minimum": 0 },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topicId", "prerequisiteId", "strength", "reason"],
        "properties": {
          "topicId": { "type": "string", "pattern": "^jt_" },
          "prerequisiteId": { "type": "string", "pattern": "^jt_" },
          "strength": { "enum": ["hard", "soft"] },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
